# ============================================================
# HCF — Human Comfort Factors
# Environment Configuration
# ============================================================
# Copy this to .env and customize as needed.
# All variables are optional — defaults work for local dev.
# Prefix all variables with HCF_ to set them.
# ============================================================

# --- General ---
HCF_ENV=development

# --- Cache ---
# HCF_CACHE_DIR=.cache
# HCF_CACHE_TTL_NETWORK=86400      # 24 hours (road network)
# HCF_CACHE_TTL_RESULT=2592000     # 30 days (scored results — all data is historical)

# --- Feature Toggles ---
# Disable any comfort factor for troubleshooting or performance.
# Set to false to exclude from scoring. Weights auto-normalize.
# HCF_ENABLE_NOISE_FACTOR=true
# HCF_ENABLE_CANOPY_FACTOR=true
# HCF_ENABLE_HEAT_FACTOR=true
# HCF_ENABLE_SAFETY_FACTOR=true
# HCF_ENABLE_TRAFFIC_FACTOR=true
# HCF_ENABLE_AQI_FACTOR=false     # Disabled by default — no street-level intervention model

# --- Air Quality (EPA AirNow) ---
# Get a free API key at: https://docs.airnowapi.org/account/request/
# Required only if HCF_ENABLE_AQI_FACTOR=true
# HCF_AIRNOW_API_KEY=

# --- API Limits ---
# HCF_MAX_SEGMENTS_DEFAULT=200
# HCF_MAX_SEGMENTS_LIMIT=1000

# --- CORS ---
# In production, set to your frontend domain(s)
# HCF_CORS_ORIGINS=["https://your-domain.com"]
